{
  "name": "cucumber-dashboard",
  "displayName": "Cucumber Dashboard",
  "description": "BDD Dashboard for Cucumber feature files and step definitions",
  "version": "0.3.0",
  "publisher": "cinna",
  "repository": {
    "type": "git",
    "url": "https://github.com/SinaKarimi7/cucumber-dashboard.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Programming Languages"
  ],
  "keywords": [
    "cucumber",
    "gherkin",
    "bdd",
    "testing",
    "step definitions"
  ],
  "activationEvents": [
    "onView:cucumberDash.overviewView",
    "onCommand:cucumberDash.openWebDashboard",
    "onCommand:cucumberDash.reindex",
    "onCommand:cucumberDash.refreshViews",
    "onCommand:cucumberDash.search",
    "workspaceContains:**/*.feature"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Cucumber Dashboard",
      "properties": {
        "cucumberDash.featureGlobs": {
          "type": "array",
          "default": [
            "features/**/*.feature",
            "**/*.feature"
          ],
          "description": "Glob patterns to find feature files",
          "items": {
            "type": "string"
          }
        },
        "cucumberDash.stepDefGlobs": {
          "type": "array",
          "default": [
            "**/*.{steps,step,stepdefs}.{ts,js}",
            "**/*steps*/**/*.{ts,js}"
          ],
          "description": "Glob patterns to find step definition files",
          "items": {
            "type": "string"
          }
        },
        "cucumberDash.excludeGlobs": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/build/**",
            "**/.git/**"
          ],
          "description": "Glob patterns to exclude from indexing",
          "items": {
            "type": "string"
          }
        },
        "cucumberDash.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostics for undefined and ambiguous steps"
        },
        "cucumberDash.matchMode": {
          "type": "string",
          "enum": [
            "both",
            "regex",
            "expression"
          ],
          "default": "both",
          "description": "Step matching mode (regex, cucumber expressions, or both)"
        },
        "cucumberDash.persistHistory": {
          "type": "boolean",
          "default": false,
          "description": "Persist dashboard history for trend tracking (last 30 indexes)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cucumberDash",
          "title": "Cucumber",
          "icon": "$(testing-passed-icon)"
        }
      ]
    },
    "views": {
      "cucumberDash": [
        {
          "id": "cucumberDash.overviewView",
          "name": "Overview"
        },
        {
          "id": "cucumberDash.undefinedStepsView",
          "name": "Undefined Steps"
        },
        {
          "id": "cucumberDash.unusedDefsView",
          "name": "Unused Step Definitions"
        },
        {
          "id": "cucumberDash.ambiguousStepsView",
          "name": "Ambiguous Steps"
        }
      ]
    },
    "commands": [
      {
        "command": "cucumberDash.openWebDashboard",
        "title": "Open Web Dashboard",
        "category": "Cucumber",
        "icon": "$(dashboard)"
      },
      {
        "command": "cucumberDash.reindex",
        "title": "Reindex Workspace",
        "category": "Cucumber",
        "icon": "$(refresh)"
      },
      {
        "command": "cucumberDash.refreshViews",
        "title": "Refresh Views",
        "category": "Cucumber",
        "icon": "$(refresh)"
      },
      {
        "command": "cucumberDash.search",
        "title": "Search Steps & Definitions",
        "category": "Cucumber",
        "icon": "$(search)"
      },
      {
        "command": "cucumberDash.openDashboard",
        "title": "Open Dashboard",
        "category": "Cucumber"
      },
      {
        "command": "cucumberDash.generateStepStub",
        "title": "Generate Step Definition Stub",
        "category": "Cucumber"
      },
      {
        "command": "cucumberDash.showMatchingDefs",
        "title": "Show Matching Definitions",
        "category": "Cucumber"
      }
    ],
    "languages": [
      {
        "id": "feature",
        "aliases": [
          "Gherkin",
          "gherkin",
          "Cucumber"
        ],
        "extensions": [
          ".feature"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./resources/feature-file-icon.png",
          "dark": "./resources/feature-file-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "feature",
        "scopeName": "text.gherkin.feature",
        "path": "./syntaxes/gherkin.tmLanguage.json"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cucumberDash.openWebDashboard",
          "when": "view == cucumberDash.overviewView",
          "group": "navigation"
        },
        {
          "command": "cucumberDash.refreshViews",
          "when": "view == cucumberDash.overviewView",
          "group": "navigation"
        },
        {
          "command": "cucumberDash.search",
          "when": "view == cucumberDash.overviewView",
          "group": "navigation"
        },
        {
          "command": "cucumberDash.reindex",
          "when": "view == cucumberDash.overviewView"
        }
      ],
      "commandPalette": [
        {
          "command": "cucumberDash.refreshViews"
        },
        {
          "command": "cucumberDash.search"
        },
        {
          "command": "cucumberDash.reindex"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "eslint": "^8.x"
  },
  "dependencies": {
    "@cucumber/gherkin": "^27.0.0",
    "@cucumber/messages": "^24.0.0",
    "typescript": "^5.3.0"
  }
}
